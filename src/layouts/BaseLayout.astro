---
// Amioud BaseLayout — Cormorant Garamond 500 + 300-italic + Inter variable.
// Preload: Cormorant 500 latin, Inter wght variable. Italic 300 lazy-load is fine.
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource-variable/inter';
import '../styles/tokens.css';
import '../styles/global.css';
import SchemaLayer from '@components/seo/SchemaLayer.astro';
import OpenGraph from '@components/seo/OpenGraph.astro';
import DemoBanner from '@components/seo/DemoBanner.astro';
import type { SiteConfig, SchemaConfig } from '@components/types/content';

interface Props {
  title: string;
  description: string;
  site: SiteConfig;
  schema: SchemaConfig;
  isDemo?: boolean;
  demoMessage?: string;
}

const {
  title,
  description,
  site,
  schema,
  isDemo = true,
  demoMessage = "Anteprima non indicizzata. URL finale in corso di configurazione.",
} = Astro.props;

const fullTitle = title === site.name ? site.name : `${title} — ${site.name}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="last-modified" content={site.lastUpdated} />
    <meta name="theme-color" content="#f6f4ef" />
    <link rel="icon" type="image/png" href={`${base}/images/logo.png`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

    {isDemo && <meta name="robots" content="noindex, nofollow" />}

    <OpenGraph
      title={fullTitle}
      description={description}
      url={site.url}
      siteName={site.name}
    />

    <SchemaLayer
      site={site}
      schema={schema}
      pageTitle={fullTitle}
      pageDescription={description}
    />
  </head>
  <body>
    <slot />
    {isDemo && <DemoBanner enabled={isDemo} message={demoMessage} />}
  </body>
</html>
