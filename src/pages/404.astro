---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site, nav, schema } from '@data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Pagina non trovata" description="La fragranza che cerchi è altrove." site={site} schema={schema}>
  <SiteNav brandName={site.name} links={nav} logoSrc="/images/logo.png" currentPath="/404" />

  <main class="notfound">
    <div class="container notfound__inner">
      <h1 class="display notfound__title">Questa pagina non esiste.</h1>
      <p class="notfound__sub">La fragranza che cerchi è altrove.</p>
      <a href={base || '/'} class="cta-link">Torna alla home</a>
    </div>
  </main>

  <SiteFooter site={site} />
</BaseLayout>

<style>
  .notfound {
    padding-top: clamp(180px, 22vh, 300px);
    padding-bottom: var(--space-xl);
    background: var(--color-bg);
    min-height: 70vh;
    display: grid;
    place-items: center;
  }
  .notfound__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    align-items: center;
  }
  .notfound__title {
    font-size: clamp(2.5rem, 8vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }
  .notfound__sub {
    font-size: var(--text-lead);
    color: var(--color-fg-muted);
  }
</style>
