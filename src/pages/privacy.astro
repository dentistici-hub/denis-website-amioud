---
/**
 * /privacy — placeholder GDPR privacy page.
 * Copy-composer explicitly defers legal text (copy.md §4).
 * Builder inserts italian GDPR boilerplate scaffolding so the page is not empty.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site, nav, schema, legalLine } from '@data/site';
---

<BaseLayout
  title="Privacy"
  description="Informativa Privacy — Aura Company S.r.l. (Amioud)."
  site={site}
  schema={schema}
>
  <SiteNav brandName={site.name} links={nav} logoSrc="/images/logo.png" currentPath="/privacy" />

  <main class="legal">
    <div class="container legal__inner">
      <header class="legal__head">
        <p class="eyebrow">Legale</p>
        <h1 class="display legal__title">Informativa Privacy.</h1>
        <p class="legal__sub">
          Documento in aggiornamento. Per richieste, scrivere a
          <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>.
        </p>
      </header>

      <section class="prose legal__body">
        <h2 class="display legal__h2">Titolare del trattamento</h2>
        <p>{legalLine}</p>

        <h2 class="display legal__h2">Dati raccolti</h2>
        <p>
          Il sito amioud.com raccoglie dati di navigazione tecnici (log server, indirizzo IP, tipo di
          browser) e, dove presenti moduli di contatto o form rivenditori, i dati forniti volontariamente
          dall'utente (nome, email, testo della richiesta).
        </p>

        <h2 class="display legal__h2">Finalità</h2>
        <p>
          I dati sono trattati per rispondere alle richieste inviate tramite i form di contatto e per
          gestire la rete rivenditori. Non sono utilizzati per profilazione automatica.
        </p>

        <h2 class="display legal__h2">Diritti dell'interessato</h2>
        <p>
          L'interessato può richiedere in qualsiasi momento accesso, rettifica, cancellazione e
          portabilità dei propri dati scrivendo al titolare. Si applica il Regolamento UE 2016/679 (GDPR).
        </p>

        <h2 class="display legal__h2">Contatti</h2>
        <p>
          Per ogni questione relativa al trattamento dei dati personali,
          scrivere a <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>.
        </p>
      </section>
    </div>
  </main>

  <SiteFooter site={site} />
</BaseLayout>

<style>
  .legal {
    padding-top: clamp(140px, 16vh, 200px);
    padding-bottom: var(--space-xl);
    background: var(--color-bg);
  }
  .legal__inner {
    max-width: 64ch;
  }
  .legal__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }
  .legal__title {
    font-size: var(--text-h1);
    line-height: 1.02;
    letter-spacing: -0.015em;
  }
  .legal__sub {
    font-size: var(--text-body);
    color: var(--color-fg-muted);
  }
  .legal__sub a,
  .legal__body a {
    border-bottom: 1px solid var(--color-fg);
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }
  .legal__sub a:hover,
  .legal__body a:hover { color: var(--color-accent); border-bottom-color: var(--color-accent); }
  .legal__body p {
    margin-bottom: 1em;
    color: var(--color-fg-muted);
  }
  .legal__h2 {
    font-size: var(--text-h3);
    line-height: 1.1;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-fg);
  }
</style>
