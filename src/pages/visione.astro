---
/**
 * /visione — brand story long-form.
 * Sections: hero → origine → filiera → formula → founders (text only, no portraits —
 * per concept.md §7 needs_denis: team-manuel-caputo portrait missing, drop block if assent)
 * → valori marquee.
 *
 * Founders block: text-only. Concept rule: "Luxury: mai stock per persone reali" —
 * instead of hiding entirely we keep the body prose without any faces.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import KenBurnsImage from '@motion/KenBurnsImage.astro';
import ClipMaskReveal from '@motion/ClipMaskReveal.astro';
import Marquee from '@motion/Marquee.astro';
import { site, nav, schema } from '@data/site';
---

<BaseLayout
  title="Visione"
  description="Gioielleria della testa — la storia di Amioud, brand di Aura Company. Diciotto mesi di ricerca fra Grasse e Perugia per il primo extrait de parfum al mondo per capelli."
  site={site}
  schema={schema}
>
  <SiteNav brandName={site.name} links={nav} logoSrc="/images/logo.png" currentPath="/visione" />

  <main>
    {/* ============ VISIONE HERO ============ */}
    <section class="vh" aria-labelledby="vh-title">
      <div class="container vh__grid">
        <div class="vh__copy">
          <p class="eyebrow vh__eyebrow" data-animate="fade-up">Visione</p>
          <ClipMaskReveal direction="up" duration={0.9} ease="expo.out" start="top 85%">
            <h1 id="vh-title" class="display vh__title">Gioielleria della testa.</h1>
          </ClipMaskReveal>
          <p class="pull-quote vh__pull" data-animate="fade-up">
            <em>Un profumo che non si indossa, si respira.</em>
          </p>
        </div>
      </div>
    </section>

    {/* ============ ORIGINE ============ */}
    <section class="section v-block" aria-labelledby="v-origine-title">
      <div class="container v-block__grid">
        <div class="v-block__side">
          <p class="eyebrow" data-animate="fade-up">Origine</p>
          <h2 id="v-origine-title" class="display v-block__title" data-animate="fade-up">
            Diciotto mesi fra Grasse e Perugia.
          </h2>
        </div>
        <div class="prose v-block__body" data-animate-group="fade-up">
          <p>
            Aura Company nasce a Torino il 7 luglio 2025 per portare la profumeria artistica su un
            terreno che nessuno aveva ancora esplorato: i capelli.
          </p>
          <p>
            Diciotto mesi di lavoro fra le maison essenziere di Grasse e i Laboratori Sabatel di
            Perugia hanno prodotto una formula brevettata, un extrait al 20% pensato per la fibra
            capillare e non per la pelle.
          </p>
        </div>
      </div>
    </section>

    {/* ============ FILIERA — onyx band ============ */}
    <section class="section v-filiera" aria-labelledby="v-filiera-title">
      <div class="container v-filiera__grid">
        <div class="v-filiera__image">
          <KenBurnsImage
            src="/images/visione-editorial-1.jpg"
            alt="Violet Collection — tre flaconi Amioud su podi di marmo con rami di lavanda"
            direction="drift"
            duration={28}
            aspectRatio="4 / 5"
          />
        </div>
        <div class="v-filiera__text">
          <p class="eyebrow eyebrow--on-dark" data-animate="fade-up">Filiera</p>
          <h2 id="v-filiera-title" class="display v-filiera__title" data-animate="fade-up">
            Quattro mani, quattro luoghi.
          </h2>
          <div class="prose prose--on-dark" data-animate-group="fade-up">
            <p>
              Le essenze: maison di Grasse. La formula e l'imbottigliamento: Laboratori Sabatel, Perugia.
              Il packaging: Xuzhou S Moon Glass Products. La logistica: SAVE Logistica, Fiano Romano.
            </p>
            <p>La distribuzione italiana: Roby Profumi. Una filiera corta, dichiarata, verificabile.</p>
          </div>
        </div>
      </div>
    </section>

    {/* ============ FORMULA ============ */}
    <section class="section v-block" aria-labelledby="v-formula-title">
      <div class="container v-block__grid">
        <div class="v-block__side">
          <p class="eyebrow" data-animate="fade-up">Formula</p>
          <h2 id="v-formula-title" class="display v-block__title" data-animate="fade-up">
            Extrait al 20%. Per i capelli, non per la pelle.
          </h2>
        </div>
        <div class="prose v-block__body" data-animate-group="fade-up">
          <p>
            La concentrazione al 20% è ciò che definisce un extrait de parfum. Amioud è il primo
            al mondo a portarla sulla fibra capillare, in un vettore cosmetico studiato per non
            seccare il capello.
          </p>
          <p>Dentro: cheratina idrolizzata, olio di semi di lino, collagene. Brevetto depositato.</p>
        </div>
      </div>
    </section>

    {/* ============ SOCI — text-only, no portraits ============ */}
    <section class="section v-block v-block--soci" aria-labelledby="v-soci-title">
      <div class="container v-block__grid">
        <div class="v-block__side">
          <p class="eyebrow" data-animate="fade-up">Soci</p>
          <h2 id="v-soci-title" class="display v-block__title" data-animate="fade-up">Due voci, una formula.</h2>
        </div>
        <div class="prose v-block__body" data-animate-group="fade-up">
          <p>
            Aura Company è guidata da Manuel Caputo (CEO) e Sveva Motteran (Product Manager). Manuel
            presidia strategia, filiera e relazioni commerciali.
          </p>
          <p>Sveva costruisce la piramide olfattiva e dialoga con laboratori e maison essenziere.</p>
        </div>
      </div>
    </section>

    {/* ============ VALORI MARQUEE ============ */}
    {/* Why Marquee here: concept.md §6 explicit — "solo /visione — marquee dei 6 aggettivi".
        Middle-dot separators, no trailing punctuation. */}
    <section class="section v-valori" aria-label="Aggettivi brand Amioud">
      <Marquee speed={42} gap="3.5rem" class="v-valori__marquee">
        {['ETEREO', 'ONIRICO', 'UNICO', 'LEGGEREZZA', 'SOGNO', 'FLOREALE'].map((word) => (
          <span class="v-valori__word display">{word}</span>
        ))}
        {['ETEREO', 'ONIRICO', 'UNICO', 'LEGGEREZZA', 'SOGNO', 'FLOREALE'].map((word) => (
          <span class="v-valori__sep" aria-hidden="true">&middot;</span>
        ))}
      </Marquee>
    </section>
  </main>

  <SiteFooter site={site} />
</BaseLayout>

<script>
  import '../scripts/scroll-animations';
</script>

<style>
  .vh {
    padding-top: clamp(160px, 20vh, 260px);
    padding-bottom: var(--space-xl);
    background: var(--color-bg);
  }
  .vh__grid {
    display: grid;
    place-items: start;
  }
  .vh__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .vh__title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    max-width: 14ch;
  }
  .vh__pull {
    font-size: clamp(1.4rem, 3.2vw, 2.4rem);
    line-height: 1.2;
    max-width: 22ch;
    color: var(--color-fg);
  }

  .v-block { background: var(--color-bg); }
  .v-block + .v-block { border-top: 1px solid var(--color-border); }
  .v-block--soci { background: var(--color-bg-elevated); }
  .v-block__grid {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-xl);
    align-items: start;
  }
  .v-block__side {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    position: sticky;
    top: 120px;
  }
  .v-block__title {
    font-size: var(--text-h1);
    line-height: 1.02;
    letter-spacing: -0.015em;
    max-width: 16ch;
  }
  .v-block__body p {
    font-size: var(--text-lead);
    line-height: 1.55;
  }

  .v-filiera {
    background: var(--color-bg-dark);
    color: var(--color-fg-on-dark);
  }
  .v-filiera__grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-xl);
    align-items: center;
  }
  .v-filiera__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .v-filiera__title {
    font-size: var(--text-h1);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--color-fg-on-dark);
  }
  .prose--on-dark p { color: var(--color-fg-on-dark-muted); }

  .v-valori {
    background: var(--color-bg);
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .v-valori__marquee :global(.marquee__track),
  .v-valori__marquee :global(.marquee) {
    /* Primitive handles its own keyframes — we just pass content through. */
  }
  .v-valori__word {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: 0.04em;
    color: var(--color-fg);
  }
  .v-valori__sep {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    color: var(--color-fg-muted);
  }

  @media (max-width: 820px) {
    .v-block__grid,
    .v-filiera__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    .v-block__side { position: static; }
  }
</style>
