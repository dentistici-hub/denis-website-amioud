---
/**
 * SiteFooter — four columns (Fragranze / Brand / Contatti / Legale), cream background.
 * Legal line commas not em-dash (copy.md §4 alt).
 */
import type { SiteConfig } from '@components/types/content';
import { legalLine, legalCopyright, footerTagline } from '@data/site';
import { shopifyHref } from '@data/shopify-links';

interface Props { site: SiteConfig; }
const { site } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const r = (p: string) => (p.startsWith('/') ? `${base}${p}` : p);
---

<footer class="site-footer" role="contentinfo">
  <div class="container site-footer__inner">
    <div class="site-footer__brand-col">
      <a href={r('/')} class="site-footer__mark display">Amioud</a>
      <p class="site-footer__tagline">{footerTagline}</p>
    </div>

    <div class="site-footer__cols">
      <div class="site-footer__col">
        <h2 class="site-footer__col-title eyebrow">Fragranze</h2>
        <ul>
          <li><a href={r('/fragranze/amber-dusk')}>Amber Dusk</a></li>
          <li><a href={r('/fragranze/bubble-garden')}>Bubble Garden</a></li>
          <li><a href={r('/fragranze/midnight-in-florence')}>Midnight in Florence</a></li>
          <li><a href={r('/shop')}>Shop</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h2 class="site-footer__col-title eyebrow">Brand</h2>
        <ul>
          <li><a href={r('/visione')}>Visione</a></li>
          <li><a href={r('/rivenditori')}>Rivenditori</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h2 class="site-footer__col-title eyebrow">Contatti</h2>
        <ul>
          <li><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></li>
          {Object.entries(site.social).map(([name, url]) => (
            <li>
              <a href={url} target="_blank" rel="noopener noreferrer">
                {name.charAt(0).toUpperCase() + name.slice(1)}
              </a>
            </li>
          ))}
          <li>
            <a href={shopifyHref('storeRoot')} rel="noopener">Shop Amioud</a>
          </li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h2 class="site-footer__col-title eyebrow">Legale</h2>
        <ul>
          <li><a href={r('/privacy')}>Privacy</a></li>
          <li><a href={r('/cookie-policy')}>Cookie Policy</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container site-footer__legal">
    <p>{legalLine}</p>
    <p>{legalCopyright}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-bg-card);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-lg);
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(240px, 1fr) 2.4fr;
    gap: var(--space-xl);
    align-items: start;
  }
  .site-footer__brand-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .site-footer__mark {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-fg);
    letter-spacing: 0.02em;
  }
  .site-footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    max-width: 28ch;
  }
  .site-footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }
  .site-footer__col-title {
    margin-bottom: var(--space-sm);
  }
  .site-footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer__col a {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    transition: color var(--duration-fast);
  }
  .site-footer__col a:hover {
    color: var(--color-accent);
  }
  .site-footer__legal {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .site-footer__legal p {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: var(--color-fg-faint);
  }

  @media (max-width: 860px) {
    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
    .site-footer__cols {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
