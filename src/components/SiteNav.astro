---
/**
 * SiteNav — minimal transparent-over-hero nav. Onyx text on cream, no CTA button
 * (concept.md §6 nav-minimal variant, no-CTA). Active underline via accent violet
 * appears on hover + on the current-route link.
 */
import type { NavLink } from '@components/types/content';

interface Props {
  brandName: string;
  links: NavLink[];
  logoSrc?: string;
  currentPath: string;
}

const { brandName, links, logoSrc, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolved = (p: string) => (p.startsWith('/') ? `${base}${p}` : p);

function isActive(href: string): boolean {
  if (href === '/' && currentPath === '/') return true;
  if (href === '/') return false;
  return currentPath.startsWith(href);
}
---

<header class="site-nav" id="site-nav">
  <div class="site-nav__inner container">
    <a href={resolved('/')} class="site-nav__brand" aria-label={`${brandName} — home`}>
      {logoSrc ? (
        <img src={resolved(logoSrc)} alt={`${brandName} — monogramma A`} class="site-nav__logo" />
      ) : (
        <span class="site-nav__wordmark display">{brandName}</span>
      )}
    </a>

    <nav class="site-nav__links" aria-label="Navigazione principale">
      {links.map((link) => (
        <a
          href={resolved(link.href)}
          class:list={['site-nav__link', isActive(link.href) && 'is-active']}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >{link.label}</a>
      ))}
    </nav>

    <button
      class="site-nav__burger"
      id="site-nav-toggle"
      aria-expanded="false"
      aria-controls="site-nav-overlay"
      aria-label="Apri il menu"
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="site-nav__overlay" id="site-nav-overlay" aria-hidden="true">
    <nav class="site-nav__overlay-menu container" aria-label="Navigazione principale">
      <ul>
        {links.map((link, i) => (
          <li style={`--i: ${i}`}>
            <a
              href={resolved(link.href)}
              class="site-nav__overlay-link display"
              aria-current={isActive(link.href) ? 'page' : undefined}
            >{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding-block: var(--space-sm);
    transition: background var(--duration-normal) var(--ease-out),
                backdrop-filter var(--duration-normal) var(--ease-out);
  }

  .site-nav.is-scrolled {
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .site-nav__logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }

  .site-nav__wordmark {
    font-size: 1.3rem;
    letter-spacing: 0.02em;
    color: var(--color-fg);
  }

  .site-nav__links {
    display: flex;
    align-items: center;
    gap: clamp(1.25rem, 2.2vw, 2.25rem);
  }

  .site-nav__link {
    font-family: var(--font-body);
    font-weight: var(--fw-label);
    font-size: var(--text-nav);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-fg);
    padding-bottom: 0.2em;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) linear,
                color var(--duration-fast) linear;
  }

  .site-nav__link:hover {
    border-bottom-color: var(--color-accent);
    color: var(--color-accent);
  }

  .site-nav__link.is-active {
    border-bottom-color: var(--color-accent);
  }

  .site-nav__burger {
    display: none;
    background: none;
    border: none;
    width: 28px;
    height: 20px;
    flex-direction: column;
    justify-content: space-between;
    padding: 0;
    cursor: pointer;
    z-index: calc(var(--z-header) + 1);
  }
  .site-nav__burger span {
    width: 100%;
    height: 1px;
    background: var(--color-fg);
    transition: transform var(--duration-fast), opacity var(--duration-fast);
  }
  .site-nav__burger[aria-expanded='true'] span:first-child {
    transform: translateY(9px) rotate(45deg);
  }
  .site-nav__burger[aria-expanded='true'] span:last-child {
    transform: translateY(-10px) rotate(-45deg);
  }

  .site-nav__overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-header);
    background: var(--color-bg);
    display: flex;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out);
  }
  .site-nav__overlay[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }
  .site-nav__overlay ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
    padding: 0;
  }
  .site-nav__overlay-link {
    font-size: clamp(2.5rem, 10vw, 5rem);
    color: var(--color-fg);
    opacity: 0;
    transform: translateY(28px);
    transition: opacity var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out),
                color var(--duration-fast);
    transition-delay: calc(var(--i) * 0.06s);
    display: inline-block;
  }
  .site-nav__overlay[aria-hidden='false'] .site-nav__overlay-link {
    opacity: 1;
    transform: translateY(0);
  }
  .site-nav__overlay-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 760px) {
    .site-nav__links { display: none; }
    .site-nav__burger { display: flex; }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('site-nav-toggle');
  const overlay = document.getElementById('site-nav-overlay');

  if (nav && toggle && overlay) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      overlay.setAttribute('aria-hidden', String(isOpen));
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    overlay.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });

    window.addEventListener(
      'scroll',
      () => {
        if (window.scrollY > 40) nav.classList.add('is-scrolled');
        else nav.classList.remove('is-scrolled');
      },
      { passive: true },
    );
  }
</script>
