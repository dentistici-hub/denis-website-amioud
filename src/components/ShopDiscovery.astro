---
/**
 * ShopDiscovery — home product-discovery block (revise-brief P1(4)).
 * Sits between `.editorial-split` (FILIERA onyx band) and `.cta-band--quiz`.
 *
 * This is "shop", not "editorial" — so a tight 3-column grid (NOT the staggered
 * asymmetric offsets used by FragrancePreview). The asymmetric stagger already
 * reads once on the page; a second asymmetric block would blur the editorial
 * hierarchy. The staggered block is the narrative "three stories"; this block
 * is the transactional "three products to buy".
 *
 * Copy per revise-brief P1(4) directive (not committed in copy.md):
 *   - Eyebrow: "Violet Collection" (concept.md eyebrow convention, case matches
 *     existing eyebrows — uppercased via type-system.md §5 case rule)
 *   - H2: "Tre flaconi, in edizione limitata." (one line, editorial register,
 *     no marketing clichés, no "Scopri di più", no "Acquista ora", Italian
 *     with correct accents, fits type-system.md §6 ≤6 words H1 guardrail — 5 words ✓)
 *   - Card label: fragrance name (Cormorant 500, h3)
 *   - Price chip: "€ 85,00" (Italian comma decimal, Inter 500 --text-sm, onyx
 *     hairline border — intentionally quiet, not a badge/pill)
 *   - CTA: "Vai al prodotto" (hairline, per concept.md §7 rejection of "Scopri
 *     di più" generic — specific verb instead). 3 words, under type-system.md
 *     §6 CTA ≤4 words ✓. Goes to internal detail page, not Shopify.
 *
 * Motion per motion-plan.md §7 (reused verbatim from home/fragrance-prev row —
 * closest analog, same ClipMaskReveal pattern, same 60ms stagger, same durations):
 *   - ClipMaskReveal card: 800ms / power3.out / stagger 60ms
 *   - Eyebrow + H2: data-animate fade-up (700ms / power2.out, handled by script)
 *
 * Why no Acquista (Shopify) CTA here: the brief explicitly says "hairline
 * 'Acquista' OR 'Vai al prodotto' link" — one CTA per card, and the fragrance-
 * preview staggered block already surfaces "Acquista" per-card. Having three
 * "Acquista" CTAs on Home would trip CTA-dedup discipline (copy.md §6). Vai al
 * prodotto routes users to the internal detail page where the Acquista CTA
 * lives with full context.
 */
import ClipMaskReveal from '@motion/ClipMaskReveal.astro';
import { fragrances } from '@data/fragrances';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const r = (p: string) => (p.startsWith('/') ? `${base}${p}` : p);
---

<section class="section shop-discovery" aria-labelledby="shop-discovery-title">
  <div class="container shop-discovery__head">
    <p class="eyebrow shop-discovery__eyebrow" data-animate="fade-up">Violet Collection</p>
    <h2
      id="shop-discovery-title"
      class="display shop-discovery__title"
      data-animate="fade-up"
    >
      Tre flaconi, in edizione limitata.
    </h2>
  </div>

  <div class="container shop-discovery__grid">
    {fragrances.map((f, i) => (
      <ClipMaskReveal
        direction="up"
        duration={0.8}
        ease="power3.out"
        delay={i * 0.06}
        start="top 85%"
        class="shop-discovery__card-wrap"
      >
        <article class="shop-discovery__card">
          <a
            href={r(`/fragranze/${f.slug}`)}
            class="shop-discovery__image-link"
            aria-label={`${f.name} — vai al prodotto`}
          >
            <div class="shop-discovery__image">
              <img
                src={r(f.previewImage)}
                alt={`${f.name} — flacone Amioud`}
                loading="lazy"
                decoding="async"
              />
            </div>
          </a>

          <div class="shop-discovery__meta">
            <h3 class="display shop-discovery__name">
              <a href={r(`/fragranze/${f.slug}`)} class="shop-discovery__name-link">{f.name}</a>
            </h3>
            <span class="shop-discovery__price" aria-label={`Prezzo indicativo ${f.price}`}>{f.price}</span>
          </div>

          <a
            href={r(`/fragranze/${f.slug}`)}
            class="cta-link cta-link--ghost shop-discovery__cta"
          >Vai al prodotto</a>
        </article>
      </ClipMaskReveal>
    ))}
  </div>
</section>

<style>
  .shop-discovery {
    background: var(--color-bg);
  }

  .shop-discovery__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    max-width: 36ch;
  }

  .shop-discovery__title {
    font-size: var(--text-h1);
    letter-spacing: -0.015em;
    line-height: 1.02;
  }

  /* Tight grid — deliberately NOT the asymmetric stagger used by FragrancePreview.
     Three equal columns reads as "shop shelf". */
  .shop-discovery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .shop-discovery__card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .shop-discovery__image-link {
    display: block;
    text-decoration: none;
  }

  /* Square-cropped bottle — product-grid register, not magazine-card register. */
  .shop-discovery__image {
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--color-bg-elevated) 70%, var(--color-bg));
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .shop-discovery__image img {
    width: 78%;
    height: 78%;
    object-fit: contain;
    transition: transform var(--duration-normal) var(--ease-out);
  }
  .shop-discovery__image-link:hover .shop-discovery__image img {
    transform: scale(1.03);
  }

  .shop-discovery__meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-top: 0.25rem;
  }

  .shop-discovery__name {
    font-size: var(--text-h3);
    letter-spacing: -0.005em;
    line-height: 1.15;
    color: var(--color-fg);
    margin: 0;
  }
  .shop-discovery__name-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast) linear;
  }
  .shop-discovery__name-link:hover {
    border-bottom-color: var(--color-accent);
  }

  /* Price chip — hairline onyx border + Inter 500 small. No fill, no accent color:
     concept.md §5 forbids accent-as-fill. Chip reads as product metadata, not a badge. */
  .shop-discovery__price {
    font-family: var(--font-body);
    font-weight: var(--fw-ui);
    font-size: var(--text-sm);
    letter-spacing: 0.04em;
    color: var(--color-fg);
    padding: 0.22em 0.55em;
    border: 1px solid var(--color-border);
    white-space: nowrap;
    line-height: 1;
  }

  .shop-discovery__cta {
    align-self: start;
    margin-top: 0.15rem;
  }

  @media (max-width: 820px) {
    .shop-discovery__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
